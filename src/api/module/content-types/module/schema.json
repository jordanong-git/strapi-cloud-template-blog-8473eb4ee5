{
  "kind": "collectionType",
  "collectionName": "modules",
  "info": {
    "singularName": "module",
    "pluralName": "modules",
    "displayName": "Module",
    "description": "Managed curriculum modules that group related topics."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "modules",
      "required": true
    },
    "level": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::level.level",
      "inversedBy": "modules",
      "required": true
    },
    "slug": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string"
    },
    "owner_id": {
      "type": "string",
      "private": true,
      "configurable": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::topic.topic",
      "mappedBy": "module"
    },
    "questions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ip-question.ip-question",
      "mappedBy": "module"
    },
    "assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ip-asset.ip-asset",
      "mappedBy": "module"
    }
  },
  "config": {
    "attributes": {
      "owner_id": {
        "hidden": true
      },
      "organization": {
        "mainField": "name"
      }
    }
  }
}
