{
  "kind": "collectionType",
  "collectionName": "levels",
  "info": {
    "singularName": "level",
    "pluralName": "levels",
    "displayName": "Academic Level",
    "description": "Managed academic levels for IP vault content."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "code",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "owner_id": {
      "type": "string",
      "private": true,
      "configurable": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "modules": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::module.module",
      "mappedBy": "level"
    },
    "topics": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic.topic",
      "mappedBy": "level"
    },
    "questions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ip-question.ip-question",
      "mappedBy": "level"
    },
    "assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ip-asset.ip-asset",
      "mappedBy": "level"
    }
  },
  "config": {
    "attributes": {
      "owner_id": {
        "hidden": true
      }
    }
  }
}
