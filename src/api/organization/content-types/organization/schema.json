{
  "kind": "collectionType",
  "collectionName": "organizations",
  "info": {
    "singularName": "organization",
    "pluralName": "organizations",
    "displayName": "Organization",
    "description": "Tenant boundary for curriculum taxonomy, question banks, and media."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "legacy_owner_id": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::organization-membership.organization-membership",
      "mappedBy": "organization"
    },
    "levels": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::level.level",
      "mappedBy": "organization"
    },
    "modules": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::module.module",
      "mappedBy": "organization"
    },
    "topics": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::topic.topic",
      "mappedBy": "organization"
    },
    "difficulties": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::difficulty.difficulty",
      "mappedBy": "organization"
    },
    "questions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ip-question.ip-question",
      "mappedBy": "organization"
    },
    "assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ip-asset.ip-asset",
      "mappedBy": "organization"
    },
    "audit_logs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ip-audit-log.ip-audit-log",
      "mappedBy": "organization"
    }
  }
}
