{
  "kind": "collectionType",
  "collectionName": "topics",
  "info": {
    "singularName": "topic",
    "pluralName": "topics",
    "displayName": "Topic",
    "description": "Managed topic taxonomy for IP vault questions and assets."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "string"
    },
    "module": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::module.module",
      "inversedBy": "topics",
      "required": true
    },
    "level": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::level.level",
      "inversedBy": "topics",
      "required": true
    },
    "owner_id": {
      "type": "string",
      "private": true,
      "configurable": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "questions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ip-question.ip-question",
      "mappedBy": "topics"
    },
    "assets": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ip-asset.ip-asset",
      "mappedBy": "topics"
    }
  },
  "config": {
    "attributes": {
      "owner_id": {
        "hidden": true
      }
    }
  }
}
